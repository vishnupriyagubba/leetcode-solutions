class Solution:
	def isCycle(self, V, edges):
		adj=[[] for i in range(V)]
		for u,v in edges:
		    adj[u].append(v)
		    adj[v].append(u)
		visited=[False]*V
		def dfs(node,par):
		    visited[node]=True
		    for nei in adj[node]:
		        if not visited[nei]:
		            if dfs(nei,node):
		                return True
		        elif nei!=par:
		            return True
		    return False
		  
		    
		for i in range(V):
		    if not visited[i]:
		        if dfs(i,-1):
		            return True
		return False
